# Lanzalo Environment Variables
# Copy to .env and fill in your values

# ═══════════════════════════════════════
# CORE (required)
# ═══════════════════════════════════════

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require

# LLM (OpenRouter → Claude)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# ═══════════════════════════════════════
# PAYMENTS (required for revenue)
# ═══════════════════════════════════════

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# ═══════════════════════════════════════
# EMAIL (required for engagement)
# ═══════════════════════════════════════

# Resend (transactional + marketing emails)
RESEND_API_KEY=re_xxx

# ═══════════════════════════════════════
# SOCIAL MEDIA (optional but recommended)
# ═══════════════════════════════════════

# twitterapi.io ($0.003/tweet — much cheaper than official API)
TWITTERAPI_KEY=new1_xxx
TWITTER_LOGIN_COOKIES=your_cookies_from_login_v2
TWITTER_PROXY=http://user:pass@ip:port

# Late.dev (multi-platform: Instagram, TikTok, LinkedIn, etc.)
LATE_API_KEY=sk_xxx

# ═══════════════════════════════════════
# SEARCH & RESEARCH
# ═══════════════════════════════════════

# Brave Search API (for Research + Trend Scout agents)
BRAVE_API_KEY=BSA_xxx

# ═══════════════════════════════════════
# DEPLOYMENT
# ═══════════════════════════════════════

DEPLOY_DOMAIN=lanzalo.pro
RENDER_API_KEY=rnd_xxx
