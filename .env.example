# Lanzalo Environment Variables
# Generated: 2026-03-09 20:10 UTC

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lanzalo
# Railway DATABASE_URL will override this in production

# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID=your_stripe_price_id_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Fal.ai (Video Generation AI)
FAL_API_KEY=your_fal_api_key_here

# Meta Ads (Facebook/Instagram)
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_meta_ad_account_id_here

# Twitter (TwitterAPI.io)
TWITTERAPI_KEY=your_twitterapi_key_here
TWITTER_LOGIN_COOKIES=your_twitter_login_cookies_here
TWITTER_PROXY=your_twitter_proxy_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Hunter.io (Email Verification)
HUNTER_API_KEY=your_hunter_api_key_here

# Brave Search API
BRAVE_API_KEY=your_brave_api_key_here

# App Configuration
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://www.lanzalo.pro

# PostHog (Product Analytics) - Free tier: 1M eventos/mes
# Obtener en: https://posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=your_posthog_project_api_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Backend server-side tracking (misma key, sin prefijo VITE_)
POSTHOG_KEY=your_posthog_project_api_key_here
POSTHOG_HOST=https://eu.i.posthog.com