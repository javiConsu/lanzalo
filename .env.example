# Lanzalo Environment Variables
# Generated: 2026-03-09 20:10 UTC

# Clerk — Autenticación (obtener en dashboard.clerk.com → App "Lanzalo" → API Keys)
# Backend (Railway): CLERK_SECRET_KEY
CLERK_SECRET_KEY=sk_test_your_secret_key_here
# Frontend (Vercel): VITE_CLERK_PUBLISHABLE_KEY
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lanzalo
# Railway DATABASE_URL will override this in production

# LLM Provider (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
# Price IDs para cada plan (crear en Stripe Dashboard → Products → Prices)
STRIPE_PRICE_ID_STARTER=price_starter_29eur_monthly
STRIPE_PRICE_ID_PRO=price_pro_79eur_monthly
STRIPE_PRICE_ID_BUSINESS=price_business_199eur_monthly
# Legacy (deprecated - usar STRIPE_PRICE_ID_PRO)
STRIPE_PRICE_ID=your_stripe_price_id_here

# Fal.ai (Video Generation AI)
FAL_API_KEY=your_fal_api_key_here

# Meta Ads (Facebook/Instagram)
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=your_meta_ad_account_id_here

# Twitter (TwitterAPI.io)
TWITTERAPI_KEY=your_twitterapi_key_here
TWITTER_LOGIN_COOKIES=your_twitter_login_cookies_here
TWITTER_PROXY=your_twitter_proxy_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Hunter.io (Email Verification)
HUNTER_API_KEY=your_hunter_api_key_here

# Brave Search API
BRAVE_API_KEY=your_brave_api_key_here

# ScrapeCreators (Facebook Ad Library — validación de mercado)
# Obtener en: https://scrapecreators.com/ — ~1-3 créditos por análisis de viabilidad
SCRAPECREATORS_API_KEY=your_scrapecreators_api_key_here

# App Configuration
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://www.lanzalo.pro

# Sentry — Error Tracking en tiempo real
# Crear proyecto en sentry.io → Project Settings → Client Keys → DSN
SENTRY_DSN=https://your_key@o0.ingest.sentry.io/project_id
# Frontend (mismo DSN o proyecto separado en Sentry)
VITE_SENTRY_DSN=https://your_key@o0.ingest.sentry.io/project_id

# PostHog (Product Analytics) - Free tier: 1M eventos/mes
# Obtener en: https://posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=your_posthog_project_api_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Backend server-side tracking (misma key, sin prefijo VITE_)
POSTHOG_KEY=your_posthog_project_api_key_here
POSTHOG_HOST=https://eu.i.posthog.com